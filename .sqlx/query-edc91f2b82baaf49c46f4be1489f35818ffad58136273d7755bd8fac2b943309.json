{
  "db_name": "PostgreSQL",
  "query": "SELECT m.id, m.conversation_id, m.conversation_type, m.parent_id, m.author_id, u.display_name AS author_display_name, m.content, m.created_at, m.updated_at, m.deleted_at\n             FROM messages m\n             LEFT JOIN users u ON u.id = m.author_id\n             WHERE m.conversation_id = $1 AND m.deleted_at IS NULL\n             ORDER BY m.created_at DESC\n             LIMIT $2 OFFSET $3",
