{
  "extends": "../desktop/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "../desktop/src"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "../desktop/src/**/*.test.ts",
    "../desktop/src/**/*.test.tsx"
  ]
}
